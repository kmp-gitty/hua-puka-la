{
  "_comment": "Illustrative snapshot only. The LIVE review card is built by the n8n 'Build card fields' Code node (ops/n8n-reserve-seeding.json), which renders all 5 words + definitions and the Monday AND Friday pieces. This file shows the older single-piece shape for reference.",
  "cardsV2": [
    {
      "cardId": "reserve-review",
      "card": {
        "header": {
          "title": "Reserve candidate {{reserveId}}",
          "subtitle": "Review · reserve {{count}}/12"
        },
        "sections": [
          {
            "header": "Nā huaʻōlelo · Words (Mon → Fri)",
            "widgets": [{ "textParagraph": { "text": "{{words}}" } }]
          },
          {
            "header": "Pōʻakahi ʻĀpana · Monday piece",
            "widgets": [
              {
                "decoratedText": {
                  "topLabel": "{{piece_word}} · Tier {{tier}}",
                  "text": "{{piece_def}}",
                  "bottomLabel": "{{rationale}}",
                  "wrapText": true
                }
              }
            ]
          },
          {
            "widgets": [
              {
                "buttonList": {
                  "buttons": [
                    {
                      "text": "✅ Approve",
                      "onClick": { "openLink": { "url": "{{approveUrl}}" } }
                    },
                    {
                      "text": "🔁 Swap Monday",
                      "onClick": { "openLink": { "url": "{{swapUrl}}&word={{piece_source_word}}" } }
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
